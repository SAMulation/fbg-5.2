{
  "name": "@fbg/engine",
  "version": "0.0.1",
  "description": "Pure FootBored game engine — no DOM, no network, no I/O.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "build:browser": "esbuild src/index.ts --bundle --format=esm --outfile=../../public/js/engine.js --sourcemap=inline",
    "test": "vitest run",
    "test:watch": "vitest",
    "posttest": "npm run build:browser"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
