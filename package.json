{
  "name": "football-bored-game",
  "version": "1.0.0",
  "description": "A football game for bored people.",
  "main": "script2.test.js",
  "scripts": {
    "test": "jest --watchAll",
    "build:engine": "cd packages/engine && npm run build:browser",
    "build:engine:types": "cd packages/engine && npm run build",
    "test:engine": "cd packages/engine && npm run test",
    "dev": "npm run build:engine && cd packages/worker && npx wrangler dev",
    "dev:static": "node server-local.js",
    "deploy": "npm run build:engine && cd packages/worker && npx wrangler deploy",
    "harness": "cd packages/harness && node run.mjs",
    "audit": "cd packages/harness && N=50 QTR=3 node driver-stats.mjs",
    "audit:full": "cd packages/harness && N=200 QTR=7 node driver-stats.mjs",
    "audit:smoke": "cd packages/harness && N=10 QTR=3 node driver-stats.mjs",
    "replay": "cd packages/harness && node replay-game.mjs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SAMulation/fbg-5.1.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/SAMulation/fbg-5.1/issues"
  },
  "homepage": "https://github.com/SAMulation/fbg-5.1#readme",
  "devDependencies": {
    "@babel/preset-env": "^7.19.1",
    "jest": "^29.0.3",
    "netlify-lambda": "^2.0.15",
    "standard": "^17.0.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "encoding": "^0.1.13",
    "express": "^4.18.2",
    "pusher": "^5.1.1-beta",
    "random": "^3.0.6",
    "seedrandom": "^3.0.5",
    "serverless-http": "^3.1.0",
    "ws": "^8.20.0"
  }
}
